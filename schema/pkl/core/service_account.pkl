/// Grafana service account resource.
module core.service_account

import "@formae/formae.pkl"

/// A Grafana service account for programmatic API access.
@formae.ResourceHint {
  type = "Grafana::Core::ServiceAccount"
  identifier = "$.id"
}
class ServiceAccount extends formae.Resource {
  fixed hidden type: String = "Grafana::Core::ServiceAccount"

  /// Display name of the service account.
  @formae.FieldHint {}
  name: String

  /// Role assigned to the service account.
  /// One of: "None", "Viewer", "Editor", "Admin".
  @formae.FieldHint {}
  role: String = "Viewer"

  /// Whether the service account is disabled.
  @formae.FieldHint {}
  isDisabled: Boolean = false
}

/// Resolvable reference to a ServiceAccount.
class ServiceAccountResolvable extends formae.Resolvable {
  res: ServiceAccountRef
}

class ServiceAccountRef {
  id: String
  name: String
}
