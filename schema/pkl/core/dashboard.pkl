/// Grafana dashboard resource.
module core.dashboard

import "@formae/formae.pkl"

const type = "Grafana::Core::Dashboard"

/// Resolvable reference to a Dashboard.
open class DashboardResolvable extends formae.Resolvable {
  hidden type = module.type

  hidden uid: DashboardResolvable = (this) {
    property = "uid"
  }
}

/// A Grafana dashboard.
/// The dashboard body is provided as a JSON string containing panels,
/// variables, and other dashboard configuration.
@formae.ResourceHint {
  type = "Grafana::Core::Dashboard"
  identifier = "$.uid"
}
class Dashboard extends formae.Resource {
  fixed hidden type: String = "Grafana::Core::Dashboard"

  /// Unique identifier. Auto-generated if not specified.
  /// Cannot be changed after creation.
  @formae.FieldHint { createOnly = true }
  uid: String?

  /// Display title of the dashboard.
  @formae.FieldHint {}
  title: String

  /// UID of the folder containing this dashboard.
  @formae.FieldHint {}
  folderUid: (String|formae.Resolvable)?

  /// The complete dashboard model as a JSON string.
  /// This contains panels, variables, templating, annotations, etc.
  @formae.FieldHint {}
  configJson: String

  /// Commit message for the dashboard version history.
  @formae.FieldHint {}
  message: String?

  local parent = this

  hidden res: DashboardResolvable = new {
    label = parent.label
    stack = parent.stack?.label
  }
}
