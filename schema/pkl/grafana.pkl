/// Grafana plugin root module.
/// Defines target configuration and common types for Grafana resource management.
module grafana

import "@formae/formae.pkl"

/// Target configuration for a Grafana instance.
/// Contains only the deployment location, NOT credentials.
/// Authentication is provided via environment variables:
///   GRAFANA_AUTH - Service account token, API key, or "user:password" for basic auth
open class Config {
  hidden fixed type: String = "Grafana"

  /// The URL of the Grafana instance (e.g., "https://grafana.example.com").
  hidden url: String

  /// Optional organization ID. Defaults to the org associated with the auth token.
  hidden orgId: Int?

  fixed Type: String = type
  fixed Url: String = url
  fixed OrgId: Int? = orgId
}
