/// Grafana message template resource.
module alerting.message_template

import "@formae/formae.pkl"

/// A Grafana notification message template.
/// Templates use Go's text/template syntax to customize alert notification content.
@formae.ResourceHint {
  type = "Grafana::Alerting::MessageTemplate"
  identifier = "$.name"
}
class MessageTemplate extends formae.Resource {
  fixed hidden type: String = "Grafana::Alerting::MessageTemplate"

  /// Name of the template group. Used as the identifier.
  /// Cannot be changed after creation.
  @formae.FieldHint { createOnly = true }
  name: String

  /// Go template string for notification formatting.
  @formae.FieldHint {}
  template: String
}
