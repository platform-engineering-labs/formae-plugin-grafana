/// Grafana contact point resource.
module alerting.contact_point

import "@formae/formae.pkl"

/// A Grafana alerting contact point (notification channel).
/// Supports email, Slack, PagerDuty, webhook, and many other integrations.
@formae.ResourceHint {
  type = "GRAFANA::Alerting::ContactPoint"
  identifier = "$.uid"
}
class ContactPoint extends formae.Resource {
  fixed hidden type: String = "GRAFANA::Alerting::ContactPoint"

  /// Unique identifier. Auto-generated by Grafana.
  @formae.FieldHint { createOnly = true }
  uid: String?

  /// Display name of the contact point.
  /// Cannot be changed after creation (TF `grafana_contact_point.name` is
  /// `ForceNew: true`; the name is the stable handle used by downstream
  /// references such as `NotificationPolicy.receiver`).
  @formae.FieldHint { createOnly = true }
  name: String

  /// Contact point type (e.g., "email", "slack", "pagerduty", "webhook").
  @formae.FieldHint { createOnly = true }
  contactPointType: String

  /// Type-specific settings as a JSON string. This is the canonical persisted
  /// shape of a ContactPoint's settings — even when the user submitted via
  /// `settingsMap`, the handler stores the resolved values here. Read and
  /// inventory always return `settings`; `hasProviderDefault` tells the
  /// conformance harness that observing `settings` in actual state is
  /// expected, regardless of which submission form was used.
  ///
  /// Exactly one of `settings` or `settingsMap` must be set on submission.
  @formae.FieldHint { hasProviderDefault = true }
  settings: String?

  /// Type-specific settings as a key/value mapping. Each value may be a literal
  /// string or a `formae.Resolvable` pointing at another resource's property,
  /// which lets cross-plugin wiring stay in a single apply.
  ///
  /// Example — PagerDuty paging via a cross-plugin Resolvable:
  ///   settingsMap = new Mapping {
  ///     ["integrationKey"] = pdIntegration.res.integrationKey
  ///   }
  ///
  /// Exactly one of `settings` or `settingsMap` must be set.
  @formae.FieldHint {}
  settingsMap: Mapping<String, (String|formae.Resolvable)>?

  /// Whether to disable sending resolve notifications.
  @formae.FieldHint {}
  disableResolveMessage: Boolean = false
}
