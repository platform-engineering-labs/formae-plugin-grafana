/// Grafana contact point resource.
module alerting.contact_point

import "@formae/formae.pkl"

/// A Grafana alerting contact point (notification channel).
/// Supports email, Slack, PagerDuty, webhook, and many other integrations.
@formae.ResourceHint {
  type = "Grafana::Alerting::ContactPoint"
  identifier = "$.uid"
}
class ContactPoint extends formae.Resource {
  fixed hidden type: String = "Grafana::Alerting::ContactPoint"

  /// Unique identifier. Auto-generated by Grafana.
  @formae.FieldHint { createOnly = true }
  uid: String?

  /// Display name of the contact point.
  @formae.FieldHint {}
  name: String

  /// Contact point type (e.g., "email", "slack", "pagerduty", "webhook").
  @formae.FieldHint { createOnly = true }
  contactPointType: String

  /// Type-specific settings as a JSON string.
  /// Structure depends on the contact point type.
  @formae.FieldHint {}
  settings: String

  /// Whether to disable sending resolve notifications.
  @formae.FieldHint {}
  disableResolveMessage: Boolean = false
}
