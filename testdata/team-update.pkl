amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@grafana/core/team.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-stack"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK conformance test stack"
  }

  new formae.Target {
    label = "grafana-target"
    namespace = "GRAFANA"
    config = new Mapping {
      ["Type"] = "Grafana"
      ["Url"] = read("env:GRAFANA_URL")
    }
  }

  new team.Team {
    label = "test-team"
    name = "Formae Test Team \(testRunID) - Updated"
    email = "formae-test-\(testRunID)@example.com"
  }
}
