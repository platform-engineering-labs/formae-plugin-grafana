amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@grafana/alerting/message_template.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-stack"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK conformance test stack"
  }

  new formae.Target {
    label = "grafana-target"
    namespace = "GRAFANA"
    config = new Mapping {
      ["Type"] = "Grafana"
      ["Url"] = read("env:GRAFANA_URL")
    }
  }

  new message_template.MessageTemplate {
    label = "test-message-template"
    name = "formae-test-\(testRunID)-replaced"
    template = #"""
      {{ define "formae-test" }}Formae test alert: {{ .CommonLabels.alertname }}{{ end }}
      """#
  }
}
