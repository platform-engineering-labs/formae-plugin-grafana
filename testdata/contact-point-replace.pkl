amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@grafana/alerting/contact_point.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-stack"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK conformance test stack"
  }

  new formae.Target {
    label = "grafana-target"
    namespace = "GRAFANA"
    config = new Mapping {
      ["Type"] = "Grafana"
      ["Url"] = read("env:GRAFANA_URL")
    }
  }

  new contact_point.ContactPoint {
    label = "test-contact-point"
    uid = "formae-test-\(testRunID)-replaced"
    name = "Formae Test ContactPoint \(testRunID) - Replaced"
    contactPointType = "email"
    settings = #"""
      {"addresses": "formae-test@example.com", "singleEmail": true}
      """#
  }
}
