/// Basic example: manage a Grafana folder, dashboard, and data source.
amends "@formae/forma.pkl"

import "@formae/formae.pkl"
import "@grafana/grafana.pkl"
import "@grafana/core/folder.pkl"
import "@grafana/core/dashboard.pkl"
import "@grafana/core/datasource.pkl"

forma {
  new formae.Stack {
    label = "default"
    description = "Example Grafana resources"
  }

  new formae.Target {
    label = "grafana"
    namespace = "GRAFANA"
    config = new grafana.Config {
      url = "http://localhost:3000"
    }
  }

  local platformFolder = new folder.Folder {
    label = "platform-dashboards"
    uid = "platform-dashboards"
    title = "Platform Dashboards"
  }
  platformFolder

  new datasource.DataSource {
    label = "prometheus"
    uid = "prometheus"
    name = "Prometheus"
    datasourceType = "prometheus"
    url = "http://prometheus:9090"
    access = "proxy"
    isDefault = true
    jsonData = #"{"httpMethod":"POST","timeInterval":"15s"}"#
  }

  new dashboard.Dashboard {
    label = "overview"
    uid = "platform-overview"
    title = "Platform Overview"
    folderUid = platformFolder.res.uid
    configJson = #"""
      {
        "panels": [
          {
            "title": "Request Rate",
            "type": "timeseries",
            "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
            "targets": [
              {
                "datasource": {"type": "prometheus", "uid": "prometheus"},
                "expr": "rate(http_requests_total[5m])"
              }
            ]
          }
        ]
      }
      """#
  }
}
