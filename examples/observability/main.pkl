amends "@formae/forma.pkl"

import "@formae/formae.pkl"
import "@compose/compose.pkl"
import "@grafana/grafana.pkl"
import "@grafana/core/folder.pkl"
import "@grafana/core/dashboard.pkl"

description {
  text = """
    Formae Observability Stack
    ==========================

    Deploys a Grafana LGTM (Loki, Grafana, Tempo, Mimir) stack via Docker Compose
    and provisions dashboards to monitor your formae agent and plugins.

    What gets deployed:
      - Docker Compose stack with Grafana LGTM all-in-one image
      - Grafana folder "Formae Dashboards"
      - Formae Agent dashboard (command throughput, resource states, errors)
      - Formae Plugins dashboard (plugin latency, operations, error rates)

    Prerequisites:
      - Docker with Compose v2 plugin
      - GRAFANA_AUTH=admin:admin set before starting the agent

    After apply, open http://localhost:3000 (admin/admin) to view dashboards.

    Note: If the agent was already running before this stack was deployed,
    restart it so the OpenTelemetry exporter can connect to the collector:

      formae agent stop
      GRAFANA_AUTH=admin:admin formae agent start

    To destroy: formae destroy --yes main.pkl
    """
  confirm = true
}

local dashboardRepo = "https://raw.githubusercontent.com/platform-engineering-labs/formae-grafana-dashboards/main/dashboards"
local overviewJson = read("\(dashboardRepo)/formae-overview.json").text
local pluginsJson = read("\(dashboardRepo)/formae-plugin.json").text

// The compose stack that provides infrastructure
local lgtmStack = new compose.Stack {
  label = "lgtm"
  projectName = "formae-observability"
  composeFile = #"""
    services:
      lgtm:
        image: grafana/otel-lgtm:latest
        ports:
          - "3000:3000"
          - "4317:4317"
          - "4318:4318"
          - "9090:9090"
        healthcheck:
          test: ["CMD-SHELL", "curl -sf http://localhost:3000/api/health || exit 1"]
          interval: 2s
          timeout: 5s
          retries: 30
          start_period: 10s
    """#
}

forma {
  new formae.Stack {
    label = "observability"
    description = "Formae observability stack: LGTM + Grafana dashboards"
  }

  // Docker target for compose operations
  new formae.Target {
    label = "docker"
    namespace = "DOCKER"
    config = new compose.Config {}
  }

  // Grafana target — resolved from compose stack endpoints
  local grafanaTarget = new formae.Target {
    label = "grafana"
    namespace = "GRAFANA"
    config = new Mapping {
      ["Type"] = "Grafana"
      ["Endpoints"] = lgtmStack.res.endpoints
      ["EndpointKey"] = "lgtm:3000"
    }
  }
  grafanaTarget

  // The LGTM compose stack
  lgtmStack

  // Dashboards folder
  local dashboardsFolder = new folder.Folder {
    label = "formae-dashboards"
    target = grafanaTarget.res
    uid = "formae-dashboards"
    title = "Formae Dashboards"
  }
  dashboardsFolder

  // Formae Agent dashboard
  new dashboard.Dashboard {
    label = "formae-overview"
    target = grafanaTarget.res
    uid = "formae-overview"
    title = "Formae Agent"
    folderUid = dashboardsFolder.res.uid
    configJson = overviewJson
  }

  // Formae Plugins dashboard
  new dashboard.Dashboard {
    label = "formae-plugins"
    target = grafanaTarget.res
    uid = "formae-plugins"
    title = "Formae Plugins"
    folderUid = dashboardsFolder.res.uid
    configJson = pluginsJson
  }
}
